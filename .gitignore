# Python virtual environment — never commit this
.venv/
venv/
env/
ENV/

# PyInstaller build output — generated by GitHub Actions, not committed
build/
dist/
*.spec.bak

# Python cache
__pycache__/
*.py[cod]
*.pyo

# Logs — generated at runtime
logs/
*.log

# Downloaded CSVs — runtime data, not source code
downloads/*.csv
downloads/archive/

# Excel output — generated at runtime
output/*.xlsx
output/*.xls

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Editor folders
.vscode/
.idea/

# ── What IS committed (important) ──────────────────────────────────────────
# config/config.json       YES — users need the default config
# src/*.py                 YES — all source code
# main.py                  YES
# requirements.txt         YES — GitHub Actions needs this
# AutoNOC.spec             YES — GitHub Actions needs this
# .github/workflows/       YES — the build workflow itself
# generate_dummy_csv.py    YES
# run_autonoc.sh           YES
# run_autonoc.bat          YES
# README.txt               YES
